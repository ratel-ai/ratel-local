{
  "name": "@ratel-ai/ratel-local",
  "version": "0.6.0-rc.0",
  "description": "Ratel Local package: a project-scoped persistent MCP gateway plus the ratel-local CLI for managing upstream servers, OAuth, and agent imports.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "Agentified",
  "homepage": "https://github.com/ratel-ai/ratel-local",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ratel-ai/ratel-local.git"
  },
  "bugs": {
    "url": "https://github.com/ratel-ai/ratel-local/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "tool-calling",
    "ratel",
    "context-engineering",
    "gateway",
    "claude-code",
    "cli",
    "oauth"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "ratel-local": "./dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup && tsx scripts/copy-core-types.ts && tsx scripts/copy-ui-assets.ts && tsx scripts/stage-package-docs.ts",
    "prepack": "pnpm build && pnpm check:pack",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "check:pack": "tsx scripts/check-pack.ts",
    "start": "node dist/bin.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@ratel-ai/ratel-local-core": "workspace:*",
    "@ratel-ai/ratel-local-ui": "workspace:*"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ratel-ai/sdk": "^0.5.2",
    "proper-lockfile": "^4.1.2",
    "smol-toml": "^1.6.1"
  }
}
